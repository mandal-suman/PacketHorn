*.bak
*~

# Environment-specific local files
appsettings.Development.json
appsettings.Local.json
*.env

# Node artifacts (if tooling is used)
node_modules/

# PacketHorn runtime outputs (keep folders via .gitkeep if present)
logs/*
!logs/.gitkeep
outputs/pcap/*
!outputs/pcap/.gitkeep
outputs/reports/*
!outputs/reports/.gitkeep
